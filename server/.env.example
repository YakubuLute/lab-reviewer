# Copy this file to server/.env and fill in real values.
# NEVER commit server/.env to version control.

# -------------------------------------------------------
# Anthropic (get a key at https://console.anthropic.com)
# -------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# -------------------------------------------------------
# Server
# -------------------------------------------------------
PORT=3001

# -------------------------------------------------------
# GitHub (optional, but strongly recommended)
# Without a token, GitHub rate-limits to 60 requests/hour.
# Create a personal access token (read:packages scope is enough)
# at https://github.com/settings/tokens
# -------------------------------------------------------
GITHUB_TOKEN=ghp_...

# -------------------------------------------------------
# SMTP  (example uses Gmail with an App Password)
# For Gmail: enable 2FA, then generate an App Password at
# https://myaccount.google.com/apppasswords
# For Outlook/Office365: use smtp.office365.com / port 587
# -------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=nsp.labreview@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
MAIL_FROM_NAME=AmaliTech NSP Reviews
MAIL_FROM_ADDRESS=nsp.labreview@gmail.com

# -------------------------------------------------------
# Always CC this colleague on every report
# -------------------------------------------------------
CC_EMAIL=emmanuel.asaber@amalitech.com
